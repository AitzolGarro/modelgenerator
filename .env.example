# ModelGenerator Environment Configuration
# Copy this file to .env and adjust values

# --- App ---
APP_NAME=ModelGenerator
APP_VERSION=0.1.0
DEBUG=false

# --- Server ---
API_HOST=0.0.0.0
API_PORT=8000

# --- Database ---
DATABASE_URL=sqlite:///./storage/modelgenerator.db

# --- Storage ---
STORAGE_ROOT=./storage

# --- ML: Text-to-Image ---
# Options: stabilityai/stable-diffusion-xl-base-1.0, runwayml/stable-diffusion-v1-5
TEXT_TO_IMAGE_MODEL=stabilityai/stable-diffusion-xl-base-1.0
TEXT_TO_IMAGE_DEVICE=cuda
TEXT_TO_IMAGE_DTYPE=float16
IMAGE_WIDTH=1024
IMAGE_HEIGHT=1024
IMAGE_NUM_STEPS=30
IMAGE_GUIDANCE_SCALE=7.5

# --- ML: Image-to-3D Backend ---
# Options: auto (prefer InstantMesh, fall back to TripoSR), instantmesh, triposr
IMAGE_TO_3D_BACKEND=triposr

# --- ML: Image-to-3D (InstantMesh) ---
# InstantMesh is used when IMAGE_TO_3D_BACKEND=triposr or instantmesh.
# The repo is cloned to /app/instantmesh during Docker build.
# On local dev without Docker it falls back to TripoSR automatically.
#
# HuggingFace model ID for the InstantMesh weights (used by run.py internally)
INSTANTMESH_MODEL=TencentARC/InstantMesh
# Config name — maps to /app/instantmesh/configs/<name>.yaml
# Options: instant-mesh-large, instant-mesh-base, sparse-struct-large, sparse-struct-base
INSTANTMESH_CONFIG=instant-mesh-large
# Device: cuda (recommended) or cpu
INSTANTMESH_DEVICE=cuda
# Export UV texture map (requires nvdiffrast). Set false for vertex-colors-only output.
INSTANTMESH_USE_TEXTURE_MAP=true
# Marching-cubes resolution for mesh extraction
INSTANTMESH_MC_RESOLUTION=256

# --- ML: Image-to-3D (TripoSR) ---
TRIPOSR_MODEL=stabilityai/TripoSR
TRIPOSR_DEVICE=cuda
TRIPOSR_CHUNK_SIZE=8192
TRIPOSR_MC_RESOLUTION=256

# --- ML: Texturing ---
TEXTURING_ENABLED=true
TEXTURE_RESOLUTION=1024

# --- ML: UV Texturing Pipeline ---
# UV unwrapping method: "auto" (xatlas if available, then LSCM), "xatlas", "lscm"
UV_METHOD=auto
UV_TEXTURE_VIEWS=6
UV_TEXTURE_RESOLUTION=1024
CONTROLNET_DEPTH_MODEL=diffusers/controlnet-depth-sdxl-1.0
CONTROLNET_CONDITIONING_SCALE=0.8
UV_SEAM_BLEND_RADIUS=3
# Required for headless pyrender rendering (already set in Docker ENV)
# Uncomment on host if pyrender is installed:
# PYOPENGL_PLATFORM=egl

# --- Export ---
# Options: glb, obj, both
EXPORT_FORMAT=glb

# --- Worker ---
WORKER_POLL_INTERVAL=2.0
WORKER_MAX_RETRIES=2

# --- CORS ---
CORS_ORIGINS=["http://localhost:3000"]
